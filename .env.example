# =============================================
# Persona Chat - Environment Variables
# =============================================
# Copy this file to .env.local and fill in values.
# Any OpenAI-compatible chat completions endpoint works
# (OpenAI, Groq, Together, OpenRouter, Mistral, etc.)
# -------------------------------------------------------------

# LLM provider endpoint (OpenAI-compatible)
LLM_BASE_URL=https://api.openai.com/v1
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_BASE_URL=https://openrouter.ai/api/v1

# API key for the provider
LLM_API_KEY=your_api_key_here

# Model name to use
# OpenAI example:   gpt-5-mini              |  gpt-4o-mini
# Groq example:     llama-3.3-70b-versatile |  llama-3.1-8b-instant
# OpenRouter ex:    meta-llama/llama-3.3-70b-instruct
LLM_MODEL=gpt-5-mini

# Optional: max tokens per response
LLM_MAX_TOKENS=1024

# Optional: temperature (0.0 - 1.0). Lower = more deterministic.
LLM_TEMPERATURE=0.7

# Optional: cap how many recent messages are sent as context (default 20)
LLM_CONTEXT_WINDOW=20

# Optional: per-IP rate limit — max messages per window (default 10)
RATE_LIMIT_MAX=10

# Optional: rate limit window in ms (default 86400000 = 24h)
RATE_LIMIT_WINDOW_MS=86400000
